# ====================================
# LLM API 配置
# ====================================
# 请至少配置一个 API Key

# OpenAI API Key (用于 GPT-4, GPT-3.5-Turbo 等)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (用于 Claude 模型)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# 自定义 LLM 服务器配置
LITELLM_BASE_URL=http://your-llm-server:8000
LITELLM_API_KEY=sk-your-api-key-here
DEFAULT_MODEL=qwen3-code

# ====================================
# PostgreSQL 数据库配置
# ====================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_database_user
PG_PASSWORD=your_database_password
PG_DATABASE=stock
PG_OPTIONS=-c client_encoding=utf8

# 数据库连接池配置（可选）
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ====================================
# 数据验证配置（可选）
# ====================================
# 价格范围限制
VALIDATION_MIN_PRICE=0.01
VALIDATION_MAX_PRICE=10000

# 成交量范围限制
VALIDATION_MIN_VOLUME=0
VALIDATION_MAX_VOLUME=1000000000000

# 涨跌幅限制（百分比）
VALIDATION_MAX_CHANGE_PCT=20.0

# 验证模式
VALIDATION_STRICT_MODE=false
VALIDATION_AUTO_CLEAN=true
